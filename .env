# ── Application Configuration ──────────────────────────────────────────
APP_NAME="TrafficVision AI"
APP_VERSION="1.0.0"
DEBUG=true

# ── Database ────────────────────────────────────────────────────────────
# SQLite for local Windows dev (no PostgreSQL/Docker needed)
# aiosqlite driver: pip install aiosqlite
DATABASE_URL="sqlite+aiosqlite:///./backend/data/trafficvision.db"

# ── Authentication Settings ────────────────────────────────────────────
SECRET_KEY="e4d6bf542df984c6e1e8bca5a2f5f190e3ab087c7bb6293998f45a7590d98412"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Traffic Officer"

# ── File Directory Storage (relative to project root) ─────────────────
UPLOAD_DIR="./backend/data/uploads"
EVIDENCE_DIR="./backend/data/evidence"
REPORTS_DIR="./backend/data/reports"
MODELS_DIR="./backend/data/models"

# ── Model Settings ─────────────────────────────────────────────────────
YOLO_MODEL_NAME="yolo11n.pt"
YOLO_CONFIDENCE_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45
YOLO_MAX_DETECTIONS=100

# ── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]
