# ── Application Configuration ──────────────────────────────────────────
APP_NAME="TrafficVision AI"
APP_VERSION="1.0.0"
DEBUG=true

# ── Database Credentials ────────────────────────────────────────────────
# For local development, change 'db' to 'localhost' if running PostgreSQL outside docker
DATABASE_URL="postgresql+asyncpg://trafficvision:trafficvision@localhost:5432/trafficvision"

# ── Authentication Settings ────────────────────────────────────────────
SECRET_KEY="replace-this-with-a-secure-32-character-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# ── File Directory Storage ──────────────────────────────────────────────
# Inside Docker, these should map to absolute paths matched with volumes.
# For local Windows development, you can use absolute or relative paths.
# If these paths are created in the workspace, ensure you update them.
UPLOAD_DIR="./backend/data/uploads"
EVIDENCE_DIR="./backend/data/evidence"
REPORTS_DIR="./backend/data/reports"
MODELS_DIR="./backend/data/models"

# ── Model Settings ─────────────────────────────────────────────────────
YOLO_MODEL_NAME="yolo11n.pt"
YOLO_CONFIDENCE_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45
YOLO_MAX_DETECTIONS=100
